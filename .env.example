NEXT_PUBLIC_APP_URL=http://localhost:3000

# Collective web beta Firebase config.
# Leave these blank for local demo mode. The app must still render without them.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Vite-compatible names are also supported by lib/firebase.ts for portability.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional serverless AI proxy. Leave blank for MockAIService.
NEXT_PUBLIC_COLLECTIVE_AI_ENABLED=false
NEXT_PUBLIC_COLLECTIVE_AI_MOCK_MODE=true
NEXT_PUBLIC_COLLECTIVE_AI_ENDPOINT=
VITE_COLLECTIVE_AI_ENABLED=false
VITE_COLLECTIVE_AI_MOCK_MODE=true
VITE_COLLECTIVE_AI_ENDPOINT=

# Legacy prototype services. Not required for the web beta demo shell.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=
