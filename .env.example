NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Demo data ----
# true/unset = fill demo mode with a large fake community (active feel).
# Set to false to ship empty (do this when going live to real users).
NEXT_PUBLIC_DEMO_SEED=true

# ---- Supabase (live closed-beta backend) ----
# Fill these to switch the web beta from local demo mode to a real Supabase
# backend (auth, proofs, feedback, trust, storage). Leave blank for demo mode.
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Required for the demo seed script (scripts/seed-demo-data.ts).
# NEVER prefix with NEXT_PUBLIC and never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Demo population seed (server-side, scripts/seed-demo-data.ts) ----
# Shared password for demo accounts (demo+{username}@collective.local).
DEMO_USER_PASSWORD=
# Safety gate: the seed refuses to run unless this is true or --yes is passed
# (production requires both).
ALLOW_DEMO_SEED=false
# small | standard | large  (default standard; never generate large by default)
DEMO_SEED_SIZE=standard
# Opt-in: also upload tiny placeholder media to Supabase Storage (uses quota).
DEMO_UPLOAD_TO_STORAGE=false
DEMO_MEDIA_BUDGET_MB=750
# Feed controls: include seeded demo content, and (optionally) show subtle badges.
NEXT_PUBLIC_INCLUDE_DEMO_CONTENT=true
NEXT_PUBLIC_SHOW_DEMO_BADGES=false

# ---- AI support (optional) ----
NEXT_PUBLIC_COLLECTIVE_AI_ENABLED=false
NEXT_PUBLIC_COLLECTIVE_AI_MOCK_MODE=true
NEXT_PUBLIC_COLLECTIVE_AI_ENDPOINT=
OPENAI_API_KEY=

# ---- Firebase (legacy alternative backend; leave blank to use Supabase/demo) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
