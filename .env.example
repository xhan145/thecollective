# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase (server-only)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — SERVER ONLY. Never prefix with NEXT_PUBLIC_. When unset, the AI layer
# runs in mock mode (identical to today). When set, the 5 agents call real models.
OPENAI_API_KEY=
COLLECTIVE_AI_MODEL=gpt-4o-mini
COLLECTIVE_AI_MAX_TOKENS=512
COLLECTIVE_AI_TIMEOUT_MS=15000

# Google sign-in — SERVER ONLY. From Google Cloud Console (OAuth 2.0 Web client).
# When unset, the "Continue with Google" button shows a "not configured" message.
# Authorized redirect URI in Google Cloud must be: <NEXT_PUBLIC_APP_URL>/api/google/callback
# Also requires: Supabase Auth → Google provider enabled with this Web client ID allowed.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=

# Public base URL used to build the OAuth redirect (no trailing slash), e.g. https://thecollective-gh1a.vercel.app
NEXT_PUBLIC_APP_URL=

# Reveals the "Continue with Google" button. Leave unset until the two GOOGLE_WEB_* vars
# above + the Supabase Google provider are configured, then set to "true".
NEXT_PUBLIC_GOOGLE_ENABLED=
