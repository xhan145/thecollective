{
  "name": "collective-v7-android-agent-prototype",
  "version": "7.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "typecheck": "tsc --noEmit",
    "demo:assets": "tsx scripts/generate-demo-assets.ts",
    "demo:all": "npm run demo:assets && npm run seed:demo",
    "seed:demo": "tsx scripts/seed-demo-data.ts --yes",
    "seed:demo:dry": "tsx scripts/seed-demo-data.ts --dry-run",
    "seed:demo:reset": "tsx scripts/seed-demo-data.ts --reset --yes",
    "seed:demo:media": "tsx scripts/seed-demo-data.ts --media-only --yes",
    "gitnexus:analyze": "node .tools/gitnexus.mjs analyze . --index-only --name collective-v7-push-ready",
    "gitnexus:serve": "node .tools/gitnexus.mjs serve",
    "gitnexus:mcp": "node .tools/gitnexus.mjs mcp",
    "gitnexus:status": "node .tools/gitnexus.mjs status",
    "gitnexus:list": "node .tools/gitnexus.mjs list"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.105.4",
    "framer-motion": "^12.40.0",
    "lucide-react": "0.468.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.9",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.20",
    "dotenv": "^17.4.2",
    "postcss": "8.5.14",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.4",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": "20.x"
  }
}
